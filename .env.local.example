# Google Sheets Setup
# 1. Create a Google Sheet with columns: username, addedAt
# 2. Publish it to the web: File → Share → Publish to web → CSV
# 3. Paste the CSV URL below (it looks like: https://docs.google.com/spreadsheets/d/SHEET_ID/export?format=csv)
NEXT_PUBLIC_SHEET_CSV_URL=https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/export?format=csv

# Google Apps Script Web App URL (for writing new usernames)
# Instructions in README.md
NEXT_PUBLIC_SHEET_WRITE_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# Your college name (used for display only in trust-based mode)
NEXT_PUBLIC_COLLEGE_NAME=Bennett University
